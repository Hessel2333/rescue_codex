{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rescue_codex",
  "version": "0.1.4",
  "identifier": "com.hesseldev.rescue-codex",
  "build": {
    "beforeDevCommand": "node ./scripts/dev.mjs",
    "beforeBuildCommand": "node ./scripts/build.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "rescue_codex",
        "width": 1520,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczNTkzNzA1OTQzNzE2NDkKUldSSkZqZVVCVGRaY3czL09tdFZwS1lMWGM4b1lWaE1uSjhad1c1MTMxNUJZQk5aN09ZOERpRDkK",
      "endpoints": [
        "https://github.com/Hessel2333/rescue_codex/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
